# Dasko — copy this file to .env and fill in your values.
# Do NOT commit .env to git.

# Option 1: Google AI Studio (simplest)
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_api_key_here

# Option 2: Vertex AI (recommended if API key path has issues)
# Leave GEMINI_API_KEY empty and set project + location. Run: gcloud auth application-default login
# See docs/VERTEX_AI_SETUP.md for full steps.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=project-10907556-800a-42e6-b3e
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override Live API model (e.g. if your region uses a different model name)
# LIVE_MODEL=gemini-2.0-flash-live-preview-04-09
